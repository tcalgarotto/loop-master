# Copy to ~/.claude-mem/.env (chmod 600) — NEVER commit real keys
# Get key: build.nvidia.com → Profile → API Keys → Generate Personal Key

CLAUDE_MEM_OPENROUTER_API_KEY=nvapi-REPLACE_ME
# Worker provider gate reads OPENROUTER_API_KEY — set both to the same nvapi- value
OPENROUTER_API_KEY=nvapi-REPLACE_ME
